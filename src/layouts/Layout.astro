---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Simonluca Pisano - Professionista della Ristorazione" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="glow-bg glow-bg-1"></div>
		<div class="glow-bg glow-bg-2"></div>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--bg: #0a0a0a;
		--surface: rgba(255, 255, 255, 0.02);
		--surface-hover: rgba(255, 255, 255, 0.05);
		--border: rgba(255, 255, 255, 0.08);
		--text-primary: #f8fafc;
		--text-secondary: #94a3b8;
		--accent-1: #3b82f6;
		--accent-2: #8b5cf6;
		--accent-gradient: linear-gradient(135deg, var(--accent-1) 0%, var(--accent-2) 100%);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: 'Outfit', system-ui, sans-serif;
		background-color: var(--bg);
		color: var(--text-primary);
		line-height: 1.6;
		overflow-x: hidden;
		position: relative;
	}

	.glow-bg {
		position: fixed;
		width: 600px;
		height: 600px;
		border-radius: 50%;
		filter: blur(120px);
		z-index: -1;
		opacity: 0.15;
		pointer-events: none;
	}
	
	.glow-bg-1 {
		top: -20%;
		left: -10%;
		background: var(--accent-1);
	}
	
	.glow-bg-2 {
		bottom: -20%;
		right: -10%;
		background: var(--accent-2);
	}

	h1, h2, h3, h4, h5, h6 {
		font-weight: 800;
		line-height: 1.2;
		color: var(--text-primary);
	}
	
	a {
		color: var(--accent-1);
		text-decoration: none;
		transition: all 0.3s ease;
	}
	
	a:hover {
		color: var(--accent-2);
	}

	.glass {
		background: var(--surface);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 2rem;
		transition: transform 0.3s ease, background 0.3s ease;
	}

    .glass:hover {
        background: var(--surface-hover);
        transform: translateY(-2px);
    }
</style>
