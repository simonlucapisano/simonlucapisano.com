---
import { certificates } from '../data/certificates.js';

const education = [
    {
        period: "Settembre 2013 - Luglio 2018",
        title: "Cuoco / Operatore dei servizi di ristorazione",
        institution: "IPSSAR Luigi Einaudi, Lamezia Terme (IT)",
        desc: ""
    },
    {
        period: "Luglio 2013",
        title: "Vacanze-studio",
        institution: "Barnet college West Block - Londra, Inghilterra",
        desc: "Ogni giornata comprendeva quattro ore di studio della lingua inglese, visite turistiche e due ore di attività sociali."
    }
];

const courses = [
    {
        period: "Marzo 2016",
        title: "Barman / Bartender / Flair",
        desc: "Corso di formazione sulla preparazione e il servizio dei cocktail e delle bevande alcoliche e non"
    },
    {
        period: "Maggio 2016",
        title: "HACCP",
        desc: "Corso di formazione per l’applicazione delle norme UNI ENI ISO e nozioni di base dell'HACCP"
    },
    {
        period: "Maggio 2017",
        title: "Orogel",
        desc: "Legumi surgelati; Tecniche di coltura, stagionalità della produzione, processi di trattamento industriali"
    }
];
---

<div class="education-container">
    <section>
        <h2>Formazione</h2>
        <div class="grid">
            {education.map(item => (
                <div class="card glass">
                    <span class="period">{item.period}</span>
                    <h3>{item.title}</h3>
                    <p class="inst">{item.institution}</p>
                    {item.desc && <p class="desc">{item.desc}</p>}
                </div>
            ))}
        </div>
    </section>

    <section>
        <h2>Certificati</h2>
        <div class="grid">
            {certificates.map(item => (
                <a href={`/certificati/${item.slug}`} class="card glass clickable-card">
                    {item.period && <span class="period">{item.period}</span>}
                    <h3>{item.title}</h3>
                    {item.desc && <p class="desc">{item.desc}</p>}
                    <div class="action-hint">
                        Vedi certificato
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <section>
        <h2>Corsi</h2>
        <div class="grid">
            {courses.map(item => (
                <div class="card glass">
                    <span class="period">{item.period}</span>
                    <h3>{item.title}</h3>
                    <p class="desc">{item.desc}</p>
                </div>
            ))}
        </div>
    </section>
</div>

<style>
    .education-container {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        margin-top: 2rem;
    }

    h2 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
        color: var(--accent-1);
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .card {
        padding: 1.5rem;
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .period {
        font-size: 0.85rem;
        color: var(--accent-2);
        font-weight: 600;
        text-transform: uppercase;
        display: block;
        margin-bottom: 0.5rem;
    }

    h3 {
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .inst {
        font-size: 0.95rem;
        color: var(--text-secondary);
        font-style: italic;
        margin-bottom: 0.5rem;
    }

    .desc {
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    /* Stili per le card cliccabili */
    a.clickable-card {
        display: block;
        text-decoration: none;
        color: inherit;
        border-color: var(--border);
        transition: all 0.3s ease;
    }

    a.clickable-card:hover {
        border-color: var(--accent-1);
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2);
    }

    a.clickable-card h3 {
        transition: color 0.3s ease;
    }

    a.clickable-card:hover h3 {
        color: var(--accent-1);
    }

    .action-hint {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.5rem;
        color: var(--accent-1);
        font-weight: 600;
        font-size: 0.95rem;
        opacity: 0.7;
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    a.clickable-card:hover .action-hint {
        opacity: 1;
        transform: translateX(4px);
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
